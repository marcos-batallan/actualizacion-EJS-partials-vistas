<head>
  <meta charset="UTF-8">
  <title><%= title %></title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f4f6f8;
      margin: 0;
      padding: 20px;
    }

    /*
    @media (max-width: 768px) {
      .container {
        grid-template-columns: 1fr;
      }
    }

    .container {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    */
    .container {
      max-width: 1000px;
      margin: auto;
    }
    
    h1 {
      text-align: center;
    }

    .card {
      background-color: white;
      padding: 15px;
      margin-bottom: 15px;
      border-radius: 10px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .actions {
      display: flex;
      gap: 15px; /* espacio entre botones */
      margin-top: 10px;
    }

    .btn {
      padding: 8px 12px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-weight: bold;
    }

    .btn-add { background-color: #28a745; color: white; }
    .btn-edit { background-color: #8ec5ff; color: white; }
    .btn-delete { background-color: #f57582; color: white; }
    .btn-save { background-color: #007bff; color: white; width: 100%; }
    .btn-back { background-color: #6c757d; color: white; width: 100%; margin-top: 10px; }

    input {
      width: 100%;
      padding: 10px;
      margin-top: 8px;
      margin-bottom: 15px;
      border-radius: 6px;
      border: 1px solid #ccc;
    }

    .error {
      color: red;
      margin-bottom: 10px;
    }

    .main-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .main-footer {
      text-align: center;
      margin-top: 30px;
      color: gray;
      font-size: 14px;
    }
  </style>
</head>