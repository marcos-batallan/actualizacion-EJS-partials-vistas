<h1>Agregar nuevo Superhéroe</h1>

<form action="/api/heroes/agregar" method="POST">

    <input type="text" name="nombreSuperHeroe" placeholder="Nombre" required>
    <br><br>

    <input type="text" name="nombreReal" placeholder="Nombre real" required>
    <br><br>

    <input type="number" name="edad" placeholder="Edad" required>
    <br><br>

    <input type="text" name="planetaOrigen" placeholder="Planeta">
    <br><br>

    <input type="text" name="debilidad" placeholder="Debilidad">
    <br><br>

    <input type="text" name="poderes" placeholder="Poderes (separados por coma)" required>
    <br><br>

    <button type="submit">Guardar</button>
</form>

<a href="/heroes">⬅ Volver al listado</a>