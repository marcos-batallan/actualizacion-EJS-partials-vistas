
<h2>Lista de Superhéroes 🦸‍♂️</h2>

<a href="/heroes/agregar">➕ Agregar nuevo superhéroe</a>

<br><br>

<ul>
    <% superheroes.forEach(heroe => { %>
        <li>
            <strong><%= heroe.nombreSuperHeroe %></strong>
            - <%= heroe.nombreReal %>
            - Edad: <%= heroe.edad %>

            <!-- ✏️ BOTÓN EDITAR -->
            <a href="/heroes/editar/<%= heroe._id %>">
                ✏️ Editar
            </a>

            <!-- 🗑️ BOTÓN ELIMINAR -->
            <form 
                action="/api/heroes/<%= heroe._id %>?_method=DELETE" 
                method="POST" 
                style="display:inline;"
                onsubmit="return confirm('¿Seguro que querés eliminar este superhéroe?');"
            >
                <button type="submit">🗑️ Eliminar</button>
            </form>

        </li>

        <br>
    <% }) %>
</ul>